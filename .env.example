DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=false
JWT_SECRET=

# Comma-separated allowed frontend origins
# Example:
# CORS_ORIGINS=https://your-app.pages.dev,https://app.yourcompany.com
CORS_ORIGINS=

# true only if you want to allow all *.pages.dev subdomains
CORS_ALLOW_PAGES_DEV=false
